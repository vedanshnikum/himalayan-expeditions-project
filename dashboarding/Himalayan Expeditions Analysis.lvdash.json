{
  "datasets": [
    {
      "name": "0008342d",
      "displayName": "vw_expeditions",
      "queryLines": [
        "SELECT * FROM himalaya.gold.vw_expeditions"
      ]
    },
    {
      "name": "419b4f24",
      "displayName": "vw_members",
      "queryLines": [
        "SELECT * FROM himalaya.gold.vw_members"
      ]
    },
    {
      "name": "73de7c13",
      "displayName": "Average Success Rate",
      "queryLines": [
        "SELECT ROUND(SUM(CASE WHEN `Success` = true THEN 1 ELSE 0 END) / NULLIF(COUNT(`Expedition ID`), 0), 3) AS `Average Success Rate (%)`\n",
        "FROM himalaya.gold.vw_expeditions"
      ]
    },
    {
      "name": "a2456164",
      "displayName": "Date Range",
      "queryLines": [
        "SELECT CONCAT(MIN(`Year`), ' — ', MAX(`Year`)) AS `Years of Data`\n",
        "FROM himalaya.gold.vw_expeditions"
      ]
    },
    {
      "name": "20d5f732",
      "displayName": "Success and Failure by year",
      "queryLines": [
        "SELECT \n",
        "    `Year`,\n",
        "    COUNT(DISTINCT CASE WHEN `Success` = true THEN `Expedition ID` END) AS `Successes`,\n",
        "    COUNT(DISTINCT CASE WHEN `Success` = false THEN `Expedition ID` END) AS `Failures`\n",
        "FROM himalaya.gold.vw_expeditions\n",
        "GROUP BY `Year`\n",
        "ORDER BY `Year`"
      ]
    },
    {
      "name": "6a7c060a",
      "displayName": "First Successful Climbed Peak",
      "queryLines": [
        "SELECT \n",
        "    `Mountain`,\n",
        "    `First Ascent Year`,\n",
        "    `First Ascent Season`,\n",
        "    `First Ascent Country`,\n",
        "    `First Ascent Members`,\n",
        "    `Height (m)`\n",
        "FROM himalaya.gold.vw_expeditions\n",
        "WHERE `First Ascent Year` IS NOT NULL\n",
        "ORDER BY `First Ascent Year` ASC\n",
        "LIMIT 1"
      ],
      "catalog": "himalaya",
      "schema": "gold"
    },
    {
      "name": "ee2219c2",
      "displayName": "Most Expeditions",
      "queryLines": [
        "SELECT `Mountain`, COUNT(DISTINCT `Expedition ID`) AS `Total Expeditions`\n",
        "FROM himalaya.gold.vw_expeditions\n",
        "GROUP BY `Mountain`\n",
        "ORDER BY `Total Expeditions` DESC\n",
        "LIMIT 1"
      ]
    }
  ],
